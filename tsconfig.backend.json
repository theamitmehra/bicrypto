{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "./dist",
    "lib": ["es2020"],
    "types": ["node"],
    "incremental": false
  },
  "files": ["./types/index.d.ts", "./types/models/index.d.ts"],
  "include": [
    "index.ts",
    "thread.ts",
    "module-alias-setup.ts",
    "backend/**/*.ts",
    "models/**/*.ts",
    "types/**/*.d.ts"
  ],
  "exclude": ["node_modules", "dist", "src", ".next"]
}
